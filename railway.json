{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "railpack"
  },
  "deploy": {
    "startCommand": "gunicorn feelio.wsgi --log-file -",
    "preDeployCommand": "python manage.py migrate --no-input && python manage.py collectstatic --no-input",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}

